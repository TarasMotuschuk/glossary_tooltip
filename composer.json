{
  "name": "glossary_tooltip/glossary_tooltip",
  "description": "Drupal module that highlights glossary terms in rendered content and displays their descriptions in tooltips.",
  "type": "drupal-custom-module",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Taras Motuschuk"
    }
  ],
  "support": {
    "issues": "https://github.com/your-org/glossary_tooltip/issues",
    "docs": "https://github.com/your-org/glossary_tooltip"
  },
  "require": {
    "php": ">=8.4",
    "drupal/core": "^11.3"
  },
  "require-dev": {
    "drupal/core-dev": "^11.3",
    "phpunit/phpunit": "^11",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "keywords": [
    "drupal",
    "glossary",
    "tooltip",
    "taxonomy"
  ],
  "minimum-stability": "stable"
}
